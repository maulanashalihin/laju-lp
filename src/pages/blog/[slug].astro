---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/BlogPost.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import BlogStyles from "../../components/BlogStyles.astro";
import BlogNavigation from "../../components/BlogNavigation.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");

    return posts.map((post) => {
        // Find the translated version of this post
        const baseSlug = post.id.replace(/-(en|id)$/, "");
        const translatedPost = posts.find(
            (p) =>
                p.id.startsWith(baseSlug + "-") &&
                p.data.language !== post.data.language,
        );

        return {
            params: { slug: post.id },
            props: {
                postId: post.id,
                translatedSlug: translatedPost?.id ?? undefined,
            },
        };
    });
}

const { postId, translatedSlug } = Astro.props;

// Get the specific post
const posts = await getCollection("blog");
const post = posts.find((p) => p.id === postId);

if (!post) {
    return Astro.redirect("/blog");
}

const { data } = post;

// Render the markdown content
const { Content } = await render(post);

const canonicalUrl = `https://laju.dev/blog/${post.id}`;

const formatDate = (date: Date, language: "en" | "id") => {
    return new Intl.DateTimeFormat(language === "en" ? "en-US" : "id-ID", {
        year: "numeric",
        month: "long",
        day: "numeric",
    }).format(date);
};
---

<Layout
    title={`${data.title} - Laju Framework`}
    description={data.description}
    language={data.language}
    pubDate={data.pubDate}
    author={data.author}
    canonicalUrl={canonicalUrl}
>
    <!-- Navigation -->
    <BlogNavigation />

    <!-- Hero Section -->
    <div class="relative bg-slate-950 overflow-hidden">
        <!-- Background gradient -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-brand-500/5 via-transparent to-transparent"
        >
        </div>

        <article class="relative py-16 md:py-24">
            <div class="container mx-auto px-6 max-w-3xl">
                <!-- Back Link -->
                <a
                    href="/blog"
                    class="inline-flex items-center gap-2 text-slate-400 hover:text-brand-400 transition-colors mb-8 group"
                >
                    <svg
                        class="w-4 h-4 transition-transform group-hover:-translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    <span>Back to Blog</span>
                </a>

                <!-- Header -->
                <header class="mb-12">
                    <!-- Tags & Language -->
                    <div class="flex items-center gap-3 mb-6 flex-wrap">
                        <span
                            class="px-3 py-1 text-xs font-semibold rounded-full bg-brand-500/10 text-brand-400 border border-brand-500/20"
                        >
                            {
                                data.language === "en"
                                    ? "🇬🇧 English"
                                    : "🇮🇩 Bahasa Indonesia"
                            }
                        </span>
                        {
                            data.tags &&
                                data.tags.map((tag) => (
                                    <span class="px-3 py-1 text-xs font-medium rounded-full bg-slate-800 text-slate-400 border border-slate-700">
                                        #{tag}
                                    </span>
                                ))
                        }
                    </div>

                    <!-- Title -->
                    <h1
                        class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-6 leading-tight"
                    >
                        {data.title}
                    </h1>

                    <!-- Description -->
                    <p
                        class="text-lg md:text-xl text-slate-400 leading-relaxed mb-8 max-w-2xl"
                    >
                        {data.description}
                    </p>

                    <!-- Author & Date -->
                    <div
                        class="flex items-center justify-between flex-wrap gap-4 pt-8 border-t border-slate-800"
                    >
                        <div class="flex items-center gap-4">
                            {
                                data.author && (
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-orange-500 flex items-center justify-center shadow-lg shadow-brand-500/25">
                                            <span class="text-white font-bold text-sm">
                                                {data.author.charAt(0)}
                                            </span>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-white">
                                                {data.author}
                                            </p>
                                            <p class="text-xs text-slate-500">
                                                Author
                                            </p>
                                        </div>
                                    </div>
                                )
                            }
                            <div class="h-8 w-px bg-slate-800"></div>
                            <time
                                datetime={data.pubDate.toISOString()}
                                class="text-sm text-slate-400"
                            >
                                {formatDate(data.pubDate, data.language)}
                            </time>
                        </div>

                        <!-- Language Switcher -->
                        <LanguageSwitcher
                            currentLanguage={data.language}
                            translatedSlug={translatedSlug}
                        />
                    </div>
                </header>

                <!-- Content -->
                <div class="markdown-content">
                    <Content />
                </div>

                <!-- Footer -->
                <footer class="mt-16 pt-8 border-t border-slate-800">
                    <div
                        class="flex items-center justify-between flex-wrap gap-4"
                    >
                        <a
                            href="/blog"
                            class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors group"
                        >
                            <svg
                                class="w-4 h-4 transition-transform group-hover:-translate-x-1"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 19l-7-7 7-7"></path>
                            </svg>
                            <span>Back to all posts</span>
                        </a>

                        <div class="flex items-center gap-4">
                            <span class="text-sm text-slate-500">Share:</span>
                            <a
                                href="https://github.com/maulanashalihin/laju"
                                class="text-slate-500 hover:text-white transition-colors"
                                title="Star on GitHub"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                                    ></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </footer>
            </div>
        </article>
    </div>

    <!-- Footer -->
    <footer class="py-12 border-t border-slate-800 bg-slate-950">
        <div class="container mx-auto px-6 text-center text-slate-500 text-sm">
            <p>
                &copy; {new Date().getFullYear()} Laju Framework. MIT License.
            </p>
        </div>
    </footer>
    <BlogStyles />
</Layout>
