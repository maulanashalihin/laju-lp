---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <!-- HERO SECTION -->
    <section class="relative min-h-screen flex items-center overflow-hidden">
        <!-- Background Effects -->
        <div class="absolute inset-0 bg-slate-950">
            <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-brand-500/10 via-slate-950 to-slate-950"
            >
            </div>
            <div
                class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:4rem_4rem]"
            >
            </div>
            <div
                class="absolute top-0 -left-4 w-96 h-96 bg-brand-500/20 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"
            >
            </div>
            <div
                class="absolute top-0 -right-4 w-96 h-96 bg-purple-500/20 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"
            >
            </div>
        </div>

        <div class="container mx-auto px-6 max-w-7xl relative z-10 pt-20">
            <div class="text-center max-w-4xl mx-auto">
                <!-- Badge -->
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 mb-8"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"
                        ></span>
                    </span>
                    <span class="text-brand-400 text-sm font-semibold"
                        >v1.0.9 — Production Ready</span
                    >
                </div>

                <!-- Headline -->
                <h1
                    class="text-5xl md:text-7xl font-black text-white mb-6 leading-tight"
                >
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-orange-500"
                        >11x Faster Than Express</span
                    ><br />
                    The Complete TypeScript & Go Framework
                </h1>

                <!-- Subheadline -->
                <p
                    class="text-xl md:text-2xl text-slate-400 mb-8 leading-relaxed max-w-3xl mx-auto"
                >
                    Combine <strong class="text-white"
                        >HyperExpress/Fiber</strong
                    > speed, <strong class="text-white">Svelte 5</strong> reactivity,
                    and <strong class="text-white">full-stack productivity</strong>.
                    Built-in auth, storage, email, testing & CI/CD. Zero config,
                    maximum velocity.
                </p>

                <!-- Version Toggle -->
                <div class="flex flex-wrap justify-center gap-4 mb-10">
                    <a
                        href="https://github.com/maulanashalihin/laju"
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 hover:border-brand-500/50 transition-all group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="fill-white size-5"
                            viewBox="0 0 448 512"
                            ><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                            <path
                                d="M16.8 32l414.4 0c9.3 0 16.8 7.5 16.8 16.8l0 414.4c0 9.3-7.5 16.8-16.8 16.8L16.8 480C7.5 480 0 472.5 0 463.2L0 48.8C0 39.5 7.5 32 16.8 32zM249 270.3l0-36.7-159.4 0 0 36.7 56.9 0 0 163.6 45.3 0 0-163.6 57.2 0zm18.1 159.3c7.3 3.7 15.9 6.5 25.9 8.4s20.5 2.8 31.5 2.8c10.8 0 21-1 30.7-3.1s18.2-5.4 25.5-10.1 13.1-10.9 17.4-18.4 6.4-17 6.4-28.2c0-8.1-1.2-15.2-3.7-21.3s-5.9-11.5-10.5-16.3-10.1-9-16.5-12.8-13.7-7.3-21.7-10.7c-5.9-2.4-11.2-4.8-15.9-7.1s-8.7-4.6-11.9-7-5.8-4.9-7.6-7.5-2.7-5.7-2.7-9c0-3.1 .8-5.8 2.4-8.3s3.8-4.6 6.7-6.4 6.5-3.1 10.7-4.1 8.9-1.5 14.1-1.5c3.7 0 7.7 .3 11.9 .8s8.4 1.4 12.6 2.6 8.3 2.6 12.3 4.4 7.7 3.8 11 6.1l0-41.8c-6.8-2.6-14.3-4.5-22.4-5.8s-17.4-1.9-27.9-1.9c-10.7 0-20.8 1.1-30.4 3.4s-18 5.8-25.2 10.7-13 11-17.2 18.5-6.3 16.5-6.3 26.9c0 13.3 3.9 24.7 11.6 34.1s19.5 17.4 35.2 23.9c6.2 2.5 11.9 5 17.3 7.4s10 4.9 13.8 7.5 7 5.4 9.2 8.5 3.4 6.6 3.4 10.5c0 2.9-.7 5.6-2.1 8s-3.5 4.6-6.4 6.4-6.4 3.2-10.7 4.3-9.3 1.5-15 1.5c-9.7 0-19.4-1.7-28.9-5.1s-18.4-8.5-26.6-15.3l0 44.7z"
                            ></path></svg
                        >

                        <span class="text-xs text-slate-500">258k req/s</span>
                    </a>
                    <a
                        href="https://github.com/maulanashalihin/laju-go"
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 hover:border-cyan-500/50 transition-all group"
                    >
                        <svg
                            class="fill-white size-10"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 640 512"
                            ><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                            <path
                                d="M400.1 194.8c-10.9 2.8-19.9 4.3-29.1 7.6-7.3 1.9-14.7 3.9-23.2 6.1l-.6 .1c-4.2 1.2-4.6 1.3-8.5-3.2-4.7-5.3-8.1-8.7-14.6-11.9-19.7-9.6-38.7-6.8-56.4 4.7-21.2 13.7-32.1 34-31.8 59.2 .3 25 17.4 45.5 41.2 48.9 22 2.8 39.8-4.6 53.8-20.5 2.1-2.6 4-5.3 6.1-8.3 .8-1 1.5-2.1 2.3-3.3l-60.1 0c-6.5 0-8.1-4-5.9-9.3 4-9.7 11.5-25.9 15.9-34 .9-1.8 3.1-5.8 6.9-5.8l101.1 0c4.5-13.4 11.8-26.9 21.6-39.7 22.7-29.9 49.3-45.5 87.2-52 31.8-5.6 61.7-2.5 88.9 15.9 24.6 16.8 39.8 39.6 43.9 69.5 5.3 42.1-6.9 76.3-36.7 105.6-19.7 20.9-44.9 34-73.9 39.9-5.6 1-11.1 1.5-16.5 2-2.9 .2-5.7 .5-8.5 .8-28.3-.6-54.2-8.7-76-27.4-15.3-13.3-25.9-29.6-31.1-48.5-3.7 7.3-8 14.4-14 21.1-21.6 29.6-50.9 48-87.9 52.9-30.6 4.1-58.9-1.8-83.9-20.5-23-17.5-36.1-40.5-39.5-69.2-4.1-34 5.9-65.4 26.4-91.3 22.2-29 51.5-47.4 87.3-53.9 29.3-6.2 57.3-1.9 82.6 15.3 16.5 10.9 28.3 25.8 36.1 43.9 1.9 2.8 .6 4.4-3.1 5.3zM48.3 200.4c-1.3 0-1.6-.6-.9-1.6l6.6-8.4c.6-.9 2.2-1.5 3.4-1.5l111.3 0c1.2 0 1.5 .9 .9 1.8l-5.3 8.1c-.6 1-2.2 1.9-3.1 1.9l-112.8-.3zM1.2 229.1c-1.2 0-1.6-.7-.9-1.6l6.5-8.4c.6-.9 2.2-1.6 3.4-1.6l142.1 0c1.2 0 1.8 1 1.5 1.9l-2.5 7.5c-.3 1.2-1.5 1.9-2.8 1.9L1.2 229.1zm74.5 26.8c-.6 .9-.3 1.8 .9 1.8l68 .3c.9 0 2.2-.9 2.2-2.1l.6-7.5c0-1.3-.6-2.2-1.9-2.2l-62.3 0c-1.2 0-2.5 .9-3.1 1.9l-4.4 7.8zm501.5-18c-.2-2.6-.3-4.8-.7-7-5.6-30.8-34-48.3-63.6-41.4-29 6.5-47.7 24.9-54.5 54.2-5.6 24.3 6.2 48.9 28.6 58.9 17.2 7.5 34.3 6.6 50.8-1.9 24.6-13.6 38-32.7 39.6-59.5-.1-1.2-.1-2.3-.2-3.3z"
                            ></path></svg
                        >

                        <span class="text-xs text-green-400 font-semibold"
                            >Faster ⚡</span
                        >
                    </a>
                </div>

                <!-- Value Props Row -->
                <div
                    class="flex flex-wrap justify-center gap-6 mb-10 text-sm text-slate-400"
                >
                    <span class="flex items-center gap-2">
                        <svg
                            class="w-5 h-5 text-green-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        258k+ req/sec (11x Express)
                    </span>
                    <span class="flex items-center gap-2">
                        <svg
                            class="w-5 h-5 text-green-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        Multi-Agent Workflow
                    </span>
                    <span class="flex items-center gap-2">
                        <svg
                            class="w-5 h-5 text-green-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path></svg
                        >
                        Auto Testing & Deploy
                    </span>
                </div>

                <!-- CTA Buttons -->
                <div
                    class="flex flex-col sm:flex-row gap-4 justify-center mb-12"
                >
                    <a
                        href="#ai-workflow"
                        class="px-8 py-4 bg-gradient-to-r from-brand-600 to-orange-600 hover:from-brand-500 hover:to-orange-500 text-white rounded-xl font-bold transition-all shadow-lg shadow-brand-500/25 flex items-center justify-center gap-2 text-lg"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                        >
                        See How It Works
                    </a>
                    <a
                        href="https://github.com/maulanashalihin/laju"
                        target="_blank"
                        class="px-8 py-4 bg-slate-900 border border-slate-700 hover:border-slate-500 text-white rounded-xl font-semibold transition-all flex items-center justify-center gap-2 text-lg"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path></svg
                        >
                        Star on GitHub
                    </a>
                </div>

                <!-- Terminal Preview -->
                <div
                    class="max-w-3xl mx-auto rounded-xl bg-slate-900 border border-slate-800 shadow-2xl overflow-hidden"
                >
                    <div
                        class="flex items-center px-4 py-3 bg-slate-950 border-b border-slate-800"
                    >
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500">
                            </div>
                            <div class="w-3 h-3 rounded-full bg-green-500">
                            </div>
                        </div>
                        <div
                            class="flex-1 text-center text-xs font-mono text-slate-500"
                        >
                            terminal
                        </div>
                    </div>
                    <div class="p-6 font-mono text-sm text-left">
                        <div class="text-slate-500 mb-2">
                            # Install and run in 30 seconds
                        </div>
                        <div class="flex gap-2 mb-2">
                            <span class="text-brand-500">➜</span>
                            <span class="text-blue-400">~</span>
                            <span class="text-slate-300"
                                >npx create-laju-app my-app && cd my-app</span
                            >
                        </div>
                        <div class="flex gap-2 mb-2">
                            <span class="text-brand-500">➜</span>
                            <span class="text-blue-400">my-app</span>
                            <span class="text-slate-300">npm run dev</span>
                        </div>
                        <div
                            class="mt-4 p-4 bg-slate-950/50 rounded-lg border border-slate-800"
                        >
                            <div
                                class="flex items-center gap-2 text-green-400 mb-2"
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                <span class="font-bold"
                                    >Laju dev server running</span
                                >
                            </div>
                            <div class="text-slate-400 text-xs space-y-1">
                                <div>
                                    ➜ Local: <span class="text-cyan-400"
                                        >http://localhost:5555</span
                                    >
                                </div>
                                <div>
                                    ➜ Latency: <span class="text-brand-400"
                                        >1.52ms</span
                                    >
                                </div>
                                <div>
                                    ➜ Auth: <span class="text-green-400"
                                        >Ready</span
                                    > (Login, Register, OAuth)
                                </div>
                                <div>
                                    ➜ Database: <span class="text-green-400"
                                        >Connected</span
                                    > (SQLite + WAL)
                                </div>
                                <div>
                                    ➜ Hot reload: <span class="text-green-400"
                                        >Active</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Social Proof -->
                <div
                    class="my-12 flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10"
                >
                    <div class="flex items-center gap-2 text-slate-400">
                        <svg
                            class="w-5 h-5 text-green-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                            ></path>
                        </svg>
                        <span class="text-sm"
                            ><strong class="text-white">100K+</strong> users served</span
                        >
                    </div>
                    <div class="flex items-center gap-2 text-slate-400">
                        <svg
                            class="w-5 h-5 text-blue-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                            ></path>
                        </svg>
                        <span class="text-sm"
                            ><strong class="text-white">MIT</strong> License</span
                        >
                    </div>
                    <div class="flex items-center gap-2 text-slate-400">
                        <svg
                            class="w-5 h-5 text-brand-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                            ></path>
                        </svg>
                        <span class="text-sm"
                            ><strong class="text-white">TS</strong> & <strong
                                class="text-white">Go</strong
                            ></span
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- COMPARISON SECTION -->
    <section class="py-24 bg-slate-900 border-y border-slate-800">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
                    Everything You Need. <span class="text-brand-500"
                        >Nothing You Don't.</span
                    >
                </h2>
                <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                    Stop assembling 20 different packages. Laju gives you a
                    complete, opinionated stack that just works — auth,
                    database, frontend, testing, and deployment included.
                </p>
            </div>

            <!-- Comparison Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
                <!-- Express.js -->
                <div
                    class="p-6 rounded-2xl bg-slate-950 border border-slate-800 hover:border-slate-700 transition-all"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 bg-white rounded-lg flex items-center justify-center"
                        >
                            <span class="text-black font-bold text-xs">Ex</span>
                        </div>
                        <div>
                            <h3 class="text-white font-bold">Express.js</h3>
                            <p class="text-slate-500 text-xs">
                                Minimalist Framework
                            </p>
                        </div>
                    </div>
                    <ul class="space-y-3 text-sm text-slate-400">
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> No built-in auth
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> No frontend integration
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> No database ORM
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> Manual testing setup
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> 11x slower (22k req/s)
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> Manual deployment
                            config
                        </li>
                    </ul>
                </div>

                <!-- Next.js -->
                <div
                    class="p-6 rounded-2xl bg-slate-950 border border-slate-800 hover:border-slate-700 transition-all"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 bg-white rounded-lg flex items-center justify-center"
                        >
                            <span class="text-black font-bold text-xs">N</span>
                        </div>
                        <div>
                            <h3 class="text-white font-bold">Next.js</h3>
                            <p class="text-slate-500 text-xs">
                                React Framework
                            </p>
                        </div>
                    </div>
                    <ul class="space-y-3 text-sm text-slate-400">
                        <li class="flex items-center gap-2">
                            <span class="text-yellow-500">~</span> React complexity
                            overhead
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> API routes separation
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> No built-in auth
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> Vercel lock-in pressure
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-yellow-500">~</span> Client-side hydration
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="text-red-500">✗</span> Complex caching rules
                        </li>
                    </ul>
                </div>

                <!-- Laju -->
                <div
                    class="p-6 rounded-2xl bg-brand-900/10 border border-brand-500/30 relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 w-32 h-32 bg-brand-500/10 rounded-full blur-3xl"
                    >
                    </div>
                    <div class="flex items-center gap-3 mb-4 relative">
                        <div
                            class="w-10 h-10 bg-gradient-to-br from-brand-500 to-orange-500 rounded-lg flex items-center justify-center"
                        >
                            <span class="text-white font-bold text-sm">L</span>
                        </div>
                        <div>
                            <h3 class="text-white font-bold">Laju</h3>
                            <p class="text-brand-400 text-xs">
                                Full-Stack Monolith
                            </p>
                        </div>
                        <div class="ml-auto">
                            <span
                                class="px-2 py-1 bg-brand-500/20 text-brand-400 text-xs rounded font-semibold"
                                >BEST</span
                            >
                        </div>
                    </div>
